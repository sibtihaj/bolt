# Generated by bolt — do not edit manually
replicaCount: {{ .ReplicaCount }}

image:
  repository: images.releases.hashicorp.com
  name: hashicorp/terraform-enterprise
  tag: "{{ .ImageTag }}"

tfe:
  hostname: "{{ .Hostname }}"
  license:
    secretName: tfe-secrets
    secretKey: TFE_LICENSE
  encryptionPassword:
    secretName: tfe-secrets
    secretKey: TFE_ENCRYPTION_PASSWORD

operationalMode: active-active

database:
  secretName: tfe-storage
  secretKey: TFE_DATABASE_URL

objectStorage:
  type: s3
  bucket:
    secretName: tfe-storage
    secretKey: TFE_S3_BUCKET
  region:
    secretName: tfe-storage
    secretKey: TFE_S3_REGION
  accessKeyId:
    secretName: tfe-storage
    secretKey: TFE_S3_ACCESS_KEY_ID
  secretAccessKey:
    secretName: tfe-storage
    secretKey: TFE_S3_SECRET_ACCESS_KEY

redis:
  secretName: tfe-storage
  secretKey: TFE_REDIS_URL

tls:
  certData:
    secretName: tfe-tls
    secretKey: tls.crt
  keyData:
    secretName: tfe-tls
    secretKey: tls.key

service:
  type: LoadBalancer
  port: 443
  annotations: {}
