# Generated by bolt — do not edit manually
name: tfe-{{ .Name }}

services:
  tfe:
    image: "images.releases.hashicorp.com/hashicorp/terraform-enterprise:{{ .ImageTag }}"
    restart: unless-stopped
    ports:
      - "443:443"
      - "80:80"
    environment:
      TFE_LICENSE: "${TFE_LICENSE}"
      TFE_ENCRYPTION_PASSWORD: "${TFE_ENCRYPTION_PASSWORD}"
      TFE_HOSTNAME: "{{ .Hostname }}"
      TFE_OPERATIONAL_MODE: "external"
      TFE_TLS_CERT_FILE: "/etc/ssl/private/tfe.crt"
      TFE_TLS_KEY_FILE: "/etc/ssl/private/tfe.key"
      TFE_TLS_CA_BUNDLE_FILE: "/etc/ssl/private/tfe.crt"
      TFE_DATABASE_URL: "${TFE_DATABASE_URL}"
      TFE_OBJECT_STORAGE_TYPE: "s3"
      TFE_OBJECT_STORAGE_S3_BUCKET: "${TFE_S3_BUCKET}"
      TFE_OBJECT_STORAGE_S3_REGION: "${TFE_S3_REGION}"
      TFE_OBJECT_STORAGE_S3_ACCESS_KEY_ID: "${TFE_S3_ACCESS_KEY_ID}"
      TFE_OBJECT_STORAGE_S3_SECRET_ACCESS_KEY: "${TFE_S3_SECRET_ACCESS_KEY}"
    volumes:
      - "{{ .TLSCertPath }}:/etc/ssl/private/tfe.crt:ro"
      - "{{ .TLSKeyPath }}:/etc/ssl/private/tfe.key:ro"
    cap_add:
      - IPC_LOCK
    healthcheck:
      test: ["CMD", "curl", "-kf", "https://localhost/_health_check"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 120s
